# Which GitHub repo to benchmark against (defaults to torvalds/linux if not set)
GITHUB_OWNER=torvalds
GITHUB_REPO=linux

# --- Direct GitHub API ---
# Optional: without this you get 60 req/hr. With it: 5000 req/hr.
# Get one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# --- Nango ---
# Sign up at https://nango.dev, create a GitHub integration, connect an account
# Secret key: https://app.nango.dev/project-settings
NANGO_SECRET_KEY=
# The connection ID you set when linking a GitHub account in Nango dashboard
NANGO_CONNECTION_ID=

# --- Merge.dev ---
# Sign up at https://merge.dev, add GitHub via their ticketing category
# Access token: https://app.merge.dev/keys
MERGE_ACCESS_TOKEN=
# Account token: shown after linking a GitHub account
MERGE_ACCOUNT_TOKEN=

# --- Composio ---
# Sign up at https://composio.dev, connect a GitHub account
# API key: https://app.composio.dev/settings
COMPOSIO_API_KEY=
# Connected account ID: shown after linking GitHub in their dashboard
COMPOSIO_CONNECTED_ACCOUNT_ID=

# --- Airbyte ---
# ELT, not request/response — requires a destination Postgres DB.
# Sign up at https://airbyte.com, create a GitHub source + Postgres destination,
# wire them into a connection, and grab its connection ID.
AIRBYTE_API_TOKEN=
AIRBYTE_CONNECTION_ID=
# Connection string for the Postgres destination Airbyte writes into
AIRBYTE_DESTINATION_DATABASE_URL=
# Table Airbyte writes GitHub issues into (defaults to "issues")
AIRBYTE_DESTINATION_TABLE=

# --- Fivetran ---
# Same ELT model as Airbyte — also requires a destination Postgres DB.
# Sign up at https://fivetran.com, set up a GitHub connector + Postgres destination.
# API key/secret: https://fivetran.com/account/settings/api-config
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_CONNECTOR_ID=
FIVETRAN_DESTINATION_DATABASE_URL=
FIVETRAN_DESTINATION_TABLE=

# --- Ampersand ---
# Sign up at https://app.withampersand.com, define a GitHub integration in
# your amp.yaml manifest, and configure a webhook destination pointed at a
# public URL (e.g. an ngrok tunnel to localhost:4242, see AMPERSAND_WEBHOOK_PORT
# below) - this has to be set up in their dashboard, the API has no
# "give me a destination" parameter at request time.
AMPERSAND_API_KEY=
AMPERSAND_PROJECT_ID=
AMPERSAND_INTEGRATION_ID=
# The group/installation whose connected GitHub account to read from
AMPERSAND_GROUP_REF=
# Local port the adapter listens on for the webhook push (default 4242)
AMPERSAND_WEBHOOK_PORT=4242
